-- --- FUNCTIONS: TOGGLE BUTTONS ---
local function CreateToggle(name, pos, callback)
    local Label = Instance.new("TextLabel")
    Label.Parent = Main
    Label.Text = name
    Label.Position = pos
    Label.Size = UDim2.new(0, 100, 0, 30)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(255, 105, 180)
    Label.TextXAlignment = "Left"

    local Btn = Instance.new("TextButton")
    Btn.Parent = Main
    Btn.Position = UDim2.new(pos.X.Scale, pos.X.Offset + 150, pos.Y.Scale, pos.Y.Offset)
    Btn.Size = UDim2.new(0, 50, 0, 20)
    Btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Start Merah
    Btn.Text = ""
    
    local state = false
    Btn.MouseButton1Click:Connect(function()
        state = not state
        Btn.BackgroundColor3 = state and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
        callback(state)
    end)
end

