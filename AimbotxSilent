-- Tombol Function (Aimbot, ESP, dll)
local function createToggle(name, pos, settingKey)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0, 30, 0, 15)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    btn.Text = ""
    
    local label = Instance.new("TextLabel", MainFrame)
    label.Text = name
    label.Position = UDim2.new(pos.X.Scale, pos.X.Offset - 100, pos.Y.Scale, pos.Y.Offset)
    label.Size = UDim2.new(0, 90, 0, 15)
    label.TextColor3 = Color3.fromRGB(255, 105, 180)
    label.TextXAlignment = "Left"

    local indicator = Instance.new("Frame", btn)
    indicator.Size = UDim2.new(0.5, 0, 1, 0)
    indicator.BackgroundColor3 = Color3.fromRGB(255, 0, 0)

    btn.MouseButton1Click:Connect(function()
        Settings[settingKey] = not Settings[settingKey]
        indicator.BackgroundColor3 = Settings[settingKey] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
        indicator.Position = Settings[settingKey] and UDim2.new(0.5, 0, 0, 0) or UDim2.new(0, 0, 0, 0)
    end)
end

